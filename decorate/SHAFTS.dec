}

Actor BD64Flare_General
{
scale 0.4
height 3
radius 6
alpha 0.4
renderstyle Add
+NOINTERACTION
+NOGRAVITY
+CLIENTSIDEONLY
}

Actor BD64RedFlare : BD64Flare_General
{
	States
	{
	Spawn:
		LENR A 0 NoDelay A_Jump(128,2)
		LENR A 2 Bright
		Stop
		LENR B 2 Bright
		Stop
	}
}

