		TNT1 A 0 A_SpawnItemEx("BD64LightShaft3upsidedown")
	Live:
		TNT1 A 0 A_SpawnItemEx("BD64ShortWhiteFlareSmallInfGrav")
		TNT1 A 0 A_SpawnItemEx("BD64WhiteFlareFloorTexture")
		TNT1 A 1
		Stop
	}
}

